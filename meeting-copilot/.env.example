# ---------------------------------------------------------------------------
# Background Meeting Co-pilot — example environment file.
# Copy to ".env" and fill in. NEVER commit your real .env (it is gitignored).
# Secrets are read from the environment or the OS keychain ONLY.
# ---------------------------------------------------------------------------

# Anthropic API key. Prefer storing this in the OS keychain (see README); this
# env var is a fallback for development. It is never logged by the app.
ANTHROPIC_API_KEY=

# --- Claude model IDs -------------------------------------------------------
# IMPORTANT: model IDs change over time. Verify the current IDs, context
# limits, and pricing against the official docs at https://docs.claude.com
# before relying on these. They are intentionally configurable (not hardcoded
# in application logic) so you can update them without code changes.
#
# Two roles are used:
#   * a fast / low-latency model for real-time suggestions
#   * a stronger model for periodic note summarization
COPILOT_MODEL_FAST=
COPILOT_MODEL_STRONG=

# --- Behaviour --------------------------------------------------------------
# Where local data (SQLite db) is stored. Defaults to an OS-appropriate dir.
COPILOT_DATA_DIR=

# If 1, raw captured audio may be written to disk (debugging only). Default 0:
# audio is processed in memory and never persisted. Audio NEVER leaves the
# machine regardless of this setting; only transcript text is sent to the API.
COPILOT_PERSIST_AUDIO=0

# Minimum confidence (0..1) below which suggestions are suppressed and the UI
# shows "no confident suggestion" instead of inventing one.
COPILOT_MIN_CONFIDENCE=0.55

# Global hotkey to toggle the suggestions overlay.
COPILOT_HOTKEY=ctrl+shift+space

# STT model size for faster-whisper (tiny, base, small, medium, large-v3).
COPILOT_WHISPER_MODEL=base

# Show the local-only consent/disclosure reminder on start (1/0).
COPILOT_CONSENT_REMINDER=1
